# Copy this file to a secret store outside the repository and replace every
# angle-bracket placeholder before deployment. Never commit the resulting file.
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Europe/Budapest

DB_HOST=<production-database-host>
DB_PORT=3306
DB_DATABASE=<production-database-name>
DB_USERNAME=<least-privilege-application-user>
DB_PASSWORD=<secret-from-hosting-secret-store>

MAIL_HOST=<authenticated-smtp-host>
MAIL_PORT=<provider-approved-tls-port>
MAIL_ENCRYPTION=<tls-or-ssl>
MAIL_USERNAME=<smtp-account>
MAIL_PASSWORD=<secret-from-hosting-secret-store>
MAIL_FROM_EMAIL=<verified-sender-address>
MAIL_FROM_NAME=A Bata

SESSION_COOKIE_SECURE=true
ADMIN_SESSION_ABSOLUTE_TIMEOUT_SECONDS=<owner-approved-value-greater-than-900>
HSTS_MAX_AGE_SECONDS=<owner-approved-positive-value>
# Exact IPs of a controlled TLS-terminating proxy, comma-separated. Leave empty
# when Apache itself terminates TLS. Never trust a subnet or arbitrary client.
TRUSTED_PROXY_IPS=

AUTH_LOGIN_IP_LIMIT=<owner-approved-value>
AUTH_LOGIN_ACCOUNT_LIMIT=<owner-approved-value>
AUTH_LOGIN_WINDOW_SECONDS=<owner-approved-value>
AUTH_LOCKOUT_SECONDS=<owner-approved-value>
AUTH_RATE_LIMIT_PEPPER=<long-random-secret>

BOOKING_BODY_MAX_BYTES=32768
BOOKING_RATE_LIMIT=<owner-approved-value>
BOOKING_RATE_WINDOW_SECONDS=<owner-approved-value>
BOOKING_RATE_LOCKOUT_SECONDS=<owner-approved-value>
BOOKING_TRUSTED_ORIGINS=https://<production-hostname>
BOOKING_POLICY_URL=/foglalasi-szabalyzat
BOOKING_POLICY_VERSION=<approved-legal-version>
PRIVACY_POLICY_URL=/adatkezelesi_tajekoztato
PRIVACY_POLICY_VERSION=<approved-legal-version>
