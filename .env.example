APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Europe/Budapest

DB_HOST=db
DB_PORT=3306
DB_DATABASE=booking_system
DB_USERNAME=booking_user
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-root-password

MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_ENCRYPTION=none
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=no-reply@abata.local
MAIL_FROM_NAME=A Bata

SESSION_COOKIE_SECURE=false
ADMIN_SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800
HSTS_MAX_AGE_SECONDS=0
# Comma-separated exact proxy IPs. Leave empty unless the reverse proxy is controlled and trusted.
TRUSTED_PROXY_IPS=
AUTH_LOGIN_IP_LIMIT=10
AUTH_LOGIN_ACCOUNT_LIMIT=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOCKOUT_SECONDS=900
AUTH_RATE_LIMIT_PEPPER=change-this-to-a-long-random-local-secret

BOOKING_BODY_MAX_BYTES=32768
BOOKING_RATE_LIMIT=10
BOOKING_RATE_WINDOW_SECONDS=60
BOOKING_RATE_LOCKOUT_SECONDS=60
BOOKING_TRUSTED_ORIGINS=http://localhost:8080
BOOKING_POLICY_URL=/foglalasi-szabalyzat
BOOKING_POLICY_VERSION=2026-07-16
PRIVACY_POLICY_URL=/adatkezelesi_tajekoztato
PRIVACY_POLICY_VERSION=development-pending-legal-approval
