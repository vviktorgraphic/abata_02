{
    "name": "petroczki/foglalasi-rendszer",
    "description": "Framework-independent booking system for a single accommodation.",
    "license": "proprietary",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "db:check": "php bin/db-check.php",
        "test": "phpunit",
        "migrate": "php bin/migrate.php"
    },
    "config": {
        "sort-packages": true
    }
}
